import math
import torch.nn.functional as F
import torch
import torch.nn as nn


class MultiHeadAttention(nn.Module):
    """多头自注意力"""
    def __init__(self, d_model, num_heads, dropout=0.1):
        super().__init__()
        # 确保 d_model 能被头数整除，每个头分到的维度才一致
        assert d_model % num_heads == 0, "d_model 必须能被 num_heads 整除"

        self.d_model = d_model          # 模型总维度
        self.num_heads = num_heads      # 注意力头数
        self.d_k = d_model // num_heads # 每个头的维度 = 64

        # 将输入投影到 Q、K、V 的线性层
        self.W_q = nn.Linear(d_model, d_model)
        self.W_k = nn.Linear(d_model, d_model)
        self.W_v = nn.Linear(d_model, d_model)

        # 将多头拼接后的结果再投影回 d_model
        self.W_o = nn.Linear(d_model, d_model)
        self.dropout = nn.Dropout(dropout)

    def scaled_dot_product_attention(self, Q, K, V, mask=None):
        """
        Q, K, V 的形状：(batch_size, num_heads, seq_len, d_k)
        """
        # 计算 Q 与 K 的点积，并除以 sqrt(d_k) 防止点积过大导致 softmax 梯度消失
        scores = torch.matmul(Q, K.transpose(-2, -1)) / math.sqrt(self.d_k)

        # 如果提供了 mask，将对应位置设为极小的负数
        # 这样在经过 softmax 后，该位置的权重会趋近于 0
        if mask is not None:
            scores = scores.masked_fill(mask == 0, -1e9)

        # 在最后一个维度（seq_len）上做 softmax，得到注意力权重
        attention_weights = F.softmax(scores, dim=-1)
        attention_weights = self.dropout(attention_weights)

        # 用注意力权重加权求和 V
        output = torch.matmul(attention_weights, V)
        return output, attention_weights

    def split_heads(self, x):
        """
        将输入拆分为多头：
        输入 x: (batch_size, seq_len, d_model)
        输出:   (batch_size, num_heads, seq_len, d_k)
        """
        batch_size, seq_len, _ = x.size()
        # 先 reshape 成 (batch, seq_len, num_heads, d_k)
        # 再调换第1和第2维 -> (batch, num_heads, seq_len, d_k)
        return x.view(batch_size, seq_len, self.num_heads, self.d_k).transpose(1, 2)

    def combine_heads(self, x):
        """
        将多头结果合并回原来的维度：
        输入 x: (batch_size, num_heads, seq_len, d_k)
        输出:   (batch_size, seq_len, d_model)
        """
        batch_size, _, seq_len, _ = x.size()
        # 先调换维度 -> (batch, seq_len, num_heads, d_k)
        # 再用 contiguous 保证内存连续后，reshape 成 (batch, seq_len, d_model)
        return x.transpose(1, 2).contiguous().view(batch_size, seq_len, self.d_model)

    def forward(self, query, key, value, mask=None):
        # 分别用 W_q、W_k、W_v 做线性变换，再拆分成多头
        Q = self.split_heads(self.W_q(query))   # (batch, num_heads, seq_len, d_k)
        K = self.split_heads(self.W_k(key))
        V = self.split_heads(self.W_v(value))

        # 计算缩放点积注意力
        attn_output, attn_weights = self.scaled_dot_product_attention(Q, K, V, mask)
        # attn_output 形状：(batch, num_heads, seq_len, d_k)

        # 合并多头，并经过 W_o 输出投影
        output = self.W_o(self.combine_heads(attn_output))
        # output 形状：(batch, seq_len, d_model)
        return output, attn_weights


class FeedForward(nn.Module):
    """位置前馈网络：对每个位置单独进行相同的全连接变换"""
    def __init__(self, d_model, d_ff, dropout=0.1):
        super().__init__()
        # 第一层将维度从 d_model 扩大到 d_ff
        self.linear1 = nn.Linear(d_model, d_ff)
        # 第二层再压缩回 d_model
        self.linear2 = nn.Linear(d_ff, d_model)
        self.dropout = nn.Dropout(dropout)

    def forward(self, x):

        return self.linear2(self.dropout(F.relu(self.linear1(x))))


class TransformerEncoderLayer(nn.Module):
    """
    Transformer 编码器层：
    包含一个多头自注意力子层和一个前馈网络子层，
    每个子层都采用残差连接（Residual Connection）和层归一化（LayerNorm）。
    """
    def __init__(self, d_model, num_heads, d_ff, dropout=0.1):
        super().__init__()
        self.self_attn = MultiHeadAttention(d_model, num_heads, dropout)
        self.feed_forward = FeedForward(d_model, d_ff, dropout)
        # 两个 LayerNorm 分别用于注意力和前馈子层之后
        self.norm1 = nn.LayerNorm(d_model)
        self.norm2 = nn.LayerNorm(d_model)
        self.dropout = nn.Dropout(dropout)

    def forward(self, x, mask=None):
        # ---- 多头自注意力 ----
        # 自注意力中，Q、K、V 都是同一个输入 x
        attn_output, _ = self.self_attn(x, x, x, mask)
        # 残差连接：将原始输入 x 与经过 Dropout 的注意力输出相加，然后做 LayerNorm
        x = self.norm1(x + self.dropout(attn_output))

        # ---- 前馈网络 ----
        ff_output = self.feed_forward(x)
        # 同样：残差连接 + LayerNorm
        x = self.norm2(x + self.dropout(ff_output))

        return x


class TransformerEncoder(nn.Module):
    """完整的 Transformer 编码器：堆叠 N 个相同的编码器层"""
    def __init__(self, num_layers, d_model, num_heads, d_ff, dropout=0.1):
        super().__init__()
        # 将 num_layers 个 TransformerEncoderLayer 放入 ModuleList
        self.layers = nn.ModuleList([
            TransformerEncoderLayer(d_model, num_heads, d_ff, dropout)
            for _ in range(num_layers)
        ])

    def forward(self, x, mask=None):
        # 输入依次经过每一层，各层共享同一个 mask
        for layer in self.layers:
            x = layer(x, mask)
        return x
